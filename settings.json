{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Write(.claude/docs/*)",
      "Edit(src/**/*.java)",
      "Agent(api-discovery)",
      "Agent(api-testing)",
      "Agent(api-consolidation)",
      "Agent(api-fixer)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}